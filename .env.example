# Firebase Realtime Database (for live viewer count)
# 1. Go to https://console.firebase.google.com
# 2. Create a new project
# 3. Add a Web app, copy the config
# 4. Go to Realtime Database → Create database (start in test mode)
# 5. Copy values below from your Firebase project settings

VITE_FB_API_KEY=your_api_key
VITE_FB_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FB_DATABASE_URL=https://your_project-default-rtdb.firebaseio.com
VITE_FB_PROJECT_ID=your_project_id
VITE_FB_APP_ID=your_app_id
